# ── App meta ──────────────────────────────────────────────────
APP_NAME=Phishing Website Detection API (Ensemble)
APP_VERSION=4.0.0
APP_ENV=development
DEBUG=false

# ── Server ────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── XGBoost Model version ─────────────────────────────────────
# Loaded as: models/phishing_deep_{MODEL_VERSION}.pkl

MODEL_VERSION=clean_v1

# ── Ensemble weights (must sum to 1.0) ────────────────────────
ENSEMBLE_XGB_WEIGHT=0.65
ENSEMBLE_NLP_WEIGHT=0.35

# ── Classification threshold ──────────────────────────────────
PHISHING_THRESHOLD=0.45

# ── Inference limits ──────────────────────────────────────────
MAX_CONCURRENT=10
TIMEOUT_SECS=15.0

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=*

# .env file configuration
METRICS_FILE_PATH=experiments/metrics_clean.json